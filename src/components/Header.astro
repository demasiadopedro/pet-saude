---
import HeaderLink from './HeaderLink.astro';
---

<header class="m-0 px-4 bg-white shadow-[0_2px_8px_rgba(0,0,0,0.05)]">
    <nav class="flex items-center justify-between">
        <h2 class="m-0 text-base">
            <a href="/" class="no-underline">
                <img src="/pet_logo_minimal.svg" alt="Logo Principal do PET SAUDE" width="56" height="56" class="w-12 h-12 md:w-14 md:h-14"/>     
            </a>
        </h2>
        
        <div class="flex items-center gap-2 md:gap-4">
            <HeaderLink href="/" class="text-xs md:text-sm px-1 md:px-2 py-1 text-black border-b-4 border-transparent hover:border-azul-claro no-underline [&.active]:border-azul-claro">
                Pagina Inicial
            </HeaderLink>
            <HeaderLink href="/blog" class="text-xs md:text-sm px-1 md:px-2 py-1 text-black border-b-4 border-transparent hover:border-azul-claro no-underline [&.active]:border-azul-claro">
                Noticias
            </HeaderLink>
            <HeaderLink href="/cenarios" class="text-xs md:text-sm px-1 md:px-2 py-1 text-black border-b-4 border-transparent hover:border-azul-claro no-underline [&.active]:border-azul-claro">
                Cenários
            </HeaderLink>
            <HeaderLink href="/documentos" class="text-xs md:text-sm px-1 md:px-2 py-1 text-black border-b-4 border-transparent hover:border-azul-claro no-underline [&.active]:border-azul-claro">
                Documentos
            </HeaderLink>
        </div>

        <div class="hidden md:flex gap-4">
            <a href="https://www.instagram.com/pet_saude_ufopa?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank" class="text-gray-800 hover:text-azul-petroleo">
                <span class="sr-only"> Nos siga no instagram</span>
                <svg viewBox="0 0 16 16" aria-hidden="true" class="w-8 h-8 fill-current">
                    <path
                        fill="currentColor"
                        d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.486-.276a2.478 2.478 0 0 1-.919-.598 2.48 2.48 0 0 1-.599-.919c-.11-.281-.24-.705-.276-1.485-.038-.843-.047-1.096-.047-3.232 0-2.136.009-2.388.047-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.919-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z"
