---
// src/components/Sobre.astro

const pilares = [
  {
    titulo: "Ensino",
    subtitulo: "Formação na Prática",
    descricao: "No PET, alunos de TI e Saúde aprendem juntos, resolvendo problemas reais do SUS. É uma formação que une teoria da sala de aula com a realidade dos postos de saúde.",
    img: "/fotos/ensino.jpg",
    letra: "E"
  },
  {
    titulo: "Pesquisa",
    subtitulo: "Soluções para a Realidade Local",
    descricao: "Investigamos as necessidades do território para criar ferramentas digitais úteis. Nosso laboratório é a Amazônia, e nosso objetivo é gerar inovações que funcionem aqui.",
    img: "/fotos/pesquisa.jpeg",
    letra: "P"
  },
  {
    titulo: "Extensão",
    subtitulo: "Tecnologia a Serviço da Comunidade",
    descricao: "Não ficamos na universidade. Levamos capacitação, oficinas de letramento digital e projetos-piloto diretamente para as unidades de saúde e a população.",
    img: "/fotos/extensao.jpeg",
    letra: "X"
  }
];
---

<section class="py-16 px-4 bg-gray-50 text-center">
    <div class="max-w-[900px] mx-auto mb-10">
        <h2 class="text-4xl font-bold text-laranja mb-6">
            O Programa PET Saúde
        </h2>
        <p class="text-lg text-gray-600 leading-relaxed text-justify mb-5">
            O <strong>Programa de Educação pelo Trabalho para a Saúde (PET Saúde)</strong> é uma iniciativa nacional que forma profissionais de saúde e tecnologia <strong>diretamente dentro do SUS</strong>, unindo universidade, serviço e comunidade.
        </p>
        <p class="text-lg text-gray-600 leading-relaxed text-justify">
            Em Santarém, somos o <strong>PET Saúde Digital (I&SD) da UFOPA</strong>. Nosso diferencial é usar essa metodologia para <strong>criar e aplicar tecnologia</strong> que resolva os desafios únicos da saúde na Amazônia.
        </p>
    </div>

    <h3 class="text-2xl font-bold text-laranja mt-12 mb-8 text-center">
        Nosso trabalho se baseia em três pilares:
    </h3>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-[1200px] mx-auto">
        {pilares.map((pilar) => (
            <div class="bg-white rounded-xl overflow-hidden shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl flex flex-col text-left group">
                
                <div class="relative h-[220px] w-full overflow-hidden">
                    <img 
                        src={pilar.img} 
                        alt={`Foto representando ${pilar.titulo}`} 
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                    />
                    <div class="absolute -bottom-5 right-5 w-[50px] h-[50px] bg-azul-petroleo rounded-full flex items-center justify-center text-white font-bold border-4 border-white text-xl z-10">
                         <span>{pilar.letra}</span>
                    </div>
                </div>

                <div class="pt-8 px-6 pb-6 flex-grow">
                    <h3 class="text-2xl font-bold text-laranja mb-1 leading-tight">
                        {pilar.titulo} 
                        <span class="block text-sm font-normal text-gray-400 mt-1">
                            | {pilar.subtitulo}
                        </span>
                    </h3>
                    <p class="text-gray-600 text-base leading-relaxed mt-4">
                        {pilar.descricao}
                    </p>
                </div>
            </div>
        ))}
    </div>
</section>