---
// src/components/Sobre.astro

const pilares = [
  {
    titulo: "Ensino",
    subtitulo: "Formação na Prática",
    descricao: "No PET, alunos de TI e Saúde aprendem juntos, resolvendo problemas reais do SUS. É uma formação que une teoria da sala de aula com a realidade dos postos de saúde.",
    img: "/fotos/ensino.jpg",
    letra: "E"
  },
  {
    titulo: "Pesquisa",
    subtitulo: "Soluções para a Realidade Local",
    descricao: "Investigamos as necessidades do território para criar ferramentas digitais úteis. Nosso laboratório é a Amazônia, e nosso objetivo é gerar inovações que funcionem aqui.",
    img: "/fotos/pesquisa.jpeg",
    letra: "P"
  },
  {
    titulo: "Extensão",
    subtitulo: "Tecnologia a Serviço da Comunidade",
    descricao: "Não ficamos na universidade. Levamos capacitação, oficinas de letramento digital e projetos-piloto diretamente para as unidades de saúde e a população.",
    img: "/fotos/extensao.jpg",
    letra: "X"
  }
];
---

<section class="sobre-container">
    <div class="header-section">
        <h2>O Programa PET Saúde</h2>
        <p>
            O <strong>Programa de Educação pelo Trabalho para a Saúde (PET Saúde)</strong> é uma iniciativa nacional que forma profissionais de saúde e tecnologia <strong>diretamente dentro do SUS</strong>, unindo universidade, serviço e comunidade.
        </p>
        <p>
            Em Santarém, somos o <strong>PET Saúde Digital (I&SD) da UFOPA</strong>. Nosso diferencial é usar essa metodologia para <strong>criar e aplicar tecnologia</strong> que resolva os desafios únicos da saúde na Amazônia.
        </p>
    </div>

    <h3 style="text-align: center; color: var(--cor-laranja); margin: 3rem 0 2rem 0;">Nosso trabalho se baseia em três pilares:</h3>

    <div class="grid-pilares">
        {pilares.map((pilar) => (
            <div class="card">
                <div class="card-image">
                    <img src={pilar.img} alt={`Foto representando ${pilar.titulo}`} />
                    <div class="icon-badge">
                         <span class="icon-text">{pilar.letra}</span>
                    </div>
                </div>
                <div class="card-content">
                    <h3>{pilar.titulo} <span class="light">| {pilar.subtitulo}</span></h3>
                    <p>{pilar.descricao}</p>
                </div>
            </div>
        ))}
    </div>
</section>

<style>
    :root {
        --pet-cor-primaria: var(--cor-laranja);
        --pet-cor-destaque: var(--cor-azul-petroleo);
        --pet-cor-texto: #4b5563;
        --pet-cor-fundo: #f8fafc;
        --pet-cor-branco: #ffffff;
    }

    .sobre-container {
        padding: 4rem 1rem;
        background-color: var(--pet-cor-fundo);
        text-align: center;
    }

    .header-section {
        max-width: 900px;
        margin: 0 auto 2.5rem auto;
    }

    .header-section h2 {
        font-size: 2.2rem;
        color: var(--pet-cor-primaria);
        margin-bottom: 1.5rem;
    }

    .header-section p {
        font-size: 1.2rem;
        color: var(--pet-cor-texto);
        line-height: 1.6;
        margin-bottom: 1.2rem;
        text-align: justify;
    }


    .grid-pilares {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .card {
        background: var(--pet-cor-branco);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        text-align: left;
        display: flex;
        flex-direction: column;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.15);
    }

    .card-image {
        position: relative;
        height: 220px;
        width: 100%;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s;
    }

    .card:hover .card-image img {
        transform: scale(1.1);
    }

    .icon-badge {
        position: absolute;
        bottom: -20px;
        right: 20px;
        width: 50px;
        height: 50px;
        background-color: var(--pet-cor-destaque);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--pet-cor-branco);
        font-weight: bold;
        border: 4px solid var(--pet-cor-branco);
        font-size: 1.5rem;
        z-index: 10;
    }

    .card-content {
        padding: 2rem 1.5rem 1.5rem 1.5rem;
        flex-grow: 1;
    }

    .card-content h3 {
        color: var(--pet-cor-primaria);
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
        line-height: 1.2;
    }

    .card-content .light {
        font-size: 0.9rem;
        color: #888;
        font-weight: normal;
        display: block;
        margin-top: 5px;
    }

    .card-content p {
        color: var(--pet-cor-texto);
        font-size: 1rem;
        line-height: 1.5;
    }

    @media (max-width: 900px) {
        .grid-pilares {
            grid-template-columns: 1fr;
            max-width: 500px;
        }
        .header-section h2 { font-size: 2rem; }
        .header-section p { font-size: 1.1rem; }
    }
</style>