---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

// --- CONFIGURAÇÃO DOS ÍCONES ---
const iconStyles = {
    pdf: "bg-red-100 text-red-600 border-red-200",
    doc: "bg-blue-100 text-blue-600 border-blue-200",
    planilha: "bg-green-100 text-green-600 border-green-200",
    drive: "bg-gray-100 text-gray-600 border-gray-200"
};

// --- LISTA DE DOCUMENTOS ---
const documentos = [
  {
    nome: "Edital de Seleção de Bolsistas 2025",
    descricao: "Regras, critérios e cronograma para seleção de novos integrantes do PET Saúde Digital.",
    data: "10/02/2024",
    tipo: "pdf", 
    link: "https://isco.ufopa.edu.br/isco/editais-2/2025/edital-de-selecao-de-discentes-para-compor-vagas-de-bolsistas-para-atuar-no-programa-de-educacao-pelo-trabalho-para-a-saude-pet-saudeinformacao-e-s/" 
  },
  {
    nome: "Modelo de Diagnostico Situacional",
    descricao: "Template padrões para cada um dos gats.",
    data: "15/12/2025",
    tipo: "drive",
    link: "https://drive.google.com/drive/folders/1QjR45Y0PkY30YLF7Xgdfy2LDi784WPop?usp=sharing"
  }
];
---

<!doctype html>
<html lang="pt-br">
    <head>
        <BaseHead title={`Documentos | ${SITE_TITLE}`} description="Downloads e editais do PET Saúde Digital UFOPA." />
    </head>
    <body class="bg-gray-50 text-gray-600 font-sans antialiased flex flex-col min-h-screen">
        <Header />
        <main class="flex-grow">
            <section class="mt-8 mb-12">
                <div class="container mx-auto px-4 max-w-[1200px]">
                    <div class="bg-azul-escuro text-white py-16 px-4 text-center rounded-xl shadow-sm">
                        <h1 class="text-3xl md:text-4xl font-bold m-0 text-white">Documentos e Materiais</h1>
                        <p class="mt-2 text-lg opacity-90">Acesse editais, modelos oficiais e arquivos públicos do projeto.</p>
                    </div>
                </div>
            </section>

            <section class="container mx-auto px-4 max-w-[800px] mb-16 flex flex-col gap-4">
                {documentos.map((doc) => (
                    <a href={doc.link} target="_blank" class="group flex flex-col sm:flex-row items-start gap-6 bg-cinza-claro border border-gray-200 p-6 rounded-xl transition-all duration-200 hover:border-laranja hover:-translate-y-0.5 hover:shadow-md no-underline">
                        
                        <div class={`w-[60px] h-[60px] rounded-lg flex items-center justify-center font-black text-sm tracking-widest flex-shrink-0 border ${iconStyles[doc.tipo] || iconStyles.drive}`}>
                            {doc.tipo === 'pdf' && <span>PDF</span>}
                            {doc.tipo === 'doc' && <span>DOC</span>}
                            {doc.tipo === 'planilha' && <span>XLS</span>}
                            {doc.tipo === 'drive' && <span>DIR</span>}
                        </div>
                        
                        <div class="flex-grow w-full">
                            <h3 class="text-xl font-semibold text-gray-800 mb-2 group-hover:text-azul-petroleo transition-colors">
                                {doc.nome}
                            </h3>
                            <p class="text-gray-500 mb-4 leading-relaxed text-base">
                                {doc.descricao}
                            </p>
                            
                            <div class="flex flex-col sm:flex-row justify-between items-center border-t border-gray-100 pt-3 gap-4 sm:gap-0 mt-auto">
                                <span class="text-sm text-gray-400 font-medium">📅 {doc.data}</span>
                                <span class="text-laranja font-bold text-sm bg-teal-50 px-6 py-2 rounded-md transition-colors w-full sm:w-auto text-center group-hover:bg-azul-petroleo group-hover:text-white">
                                    Baixar &darr;
                                </span>
                            </div>
                        </div>
                    </a>
                ))}
            </section>
        </main>
        <Footer />
    </body>
</html>