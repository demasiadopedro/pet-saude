---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

// Busca os GATs
const gats = await getCollection('gats');

// Ordena por título (GAT 1, GAT 2...)
const sortedGats = gats.sort((a, b) => 
    a.data.title.localeCompare(b.data.title, undefined, { numeric: true })
);
---

<!doctype html>
<html lang="pt-br">
    <head>
        <BaseHead title={`Cenários e GATs | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    </head>
    <body class="bg-gray-50 text-gray-600 font-sans antialiased flex flex-col min-h-screen">
        <Header />
        <main class="flex-grow">
            
            <section class="mt-8 mb-12">
                <div class="container mx-auto px-4 max-w-[1200px]">
                    <div class="bg-azul-escuro text-white py-16 px-4 text-center rounded-xl shadow-sm relative overflow-hidden">
                        <div class="relative z-10">
                            <h1 class="text-3xl md:text-5xl font-bold mb-4 text-white">Onde Atuamos?</h1>
                            <p class="text-lg md:text-xl opacity-90 max-w-2xl mx-auto">Conheça a estrutura do PET Saúde Digital e nossos cenários de prática.</p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="container mx-auto px-4 max-w-[1200px] -mt-20 relative z-20 mb-16">
                <div class="bg-white p-8 md:p-12 rounded-xl shadow-lg text-center">
                    <h2 class="text-3xl font-bold text-laranja mb-6">O que são os GATs?</h2>
                    <p class="text-lg text-gray-600 mb-10 max-w-3xl mx-auto leading-relaxed">
                        O projeto é organizado em <strong>10 Grupos de Aprendizagem Tutorial (GATs)</strong>. 
                        Eles são "células vivas" de atuação interdisciplinar presentes em 10 unidades de Saúde em 
                        <strong>Santarém e região</strong>.
                    </p>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="bg-gray-50 p-6 rounded-lg border border-gray-100 transition-transform hover:-translate-y-1">
                            <span class="block text-4xl mb-3">🎓</span>
                            <strong class="block text-lg text-azul-petroleo mb-1">Tutoria Dupla</strong>
                            <p class="text-sm text-gray-500">Docentes da Saúde + Tecnologia</p>
                        </div>
                        <div class="bg-gray-50 p-6 rounded-lg border border-gray-100 transition-transform hover:-translate-y-1">
                            <span class="block text-4xl mb-3">🩺</span>
                            <strong class="block text-lg text-azul-petroleo mb-1">Preceptoria</strong>
                            <p class="text-sm text-gray-500">Profissionais do SUS local</p>
                        </div>
                        <div class="bg-gray-50 p-6 rounded-lg border border-gray-100 transition-transform hover:-translate-y-1">
                            <span class="block text-4xl mb-3">👥</span>
                            <strong class="block text-lg text-azul-petroleo mb-1">Estudantes</strong>
                            <p class="text-sm text-gray-500">Acadêmicos da saúde e da computação</p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="container mx-auto px-4 max-w-[1200px] mb-20">
                <h2 class="text-3xl font-bold text-center text-azul-petroleo mb-10">Nossos 10 Grupos de Trabalho</h2>
                
                {sortedGats.length === 0 ? (
                    <div class="text-center p-8 bg-red-50 text-red-700 rounded-lg border border-red-100">
                        <p>⚠️ Nenhum GAT encontrado. Verifique se os arquivos .md estão na pasta <code>src/content/gats/</code>.</p>
                    </div>
                ) : (
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        {sortedGats.map((gat) => (
                            <a href={`/cenarios/${gat.id}/`} class="group bg-white border border-gray-200 rounded-xl overflow-hidden flex flex-col transition-all duration-300 hover:border-laranja hover:shadow-lg hover:-translate-y-1 no-underline">
                                
                                {/* Cabeçalho do Card (Número) */}
                                <div class="bg-gray-50 px-6 py-3 border-b border-gray-100 text-xs font-bold text-gray-400 uppercase tracking-wider">
                                    {gat.data.title.split('-')[0]}
                                </div>

                                {/* Conteúdo */}
                                <div class="p-6 flex flex-col flex-grow">
                                    <span class="inline-block bg-teal-50 text-azul-claro px-3 py-1 rounded-full text-xs font-bold uppercase mb-4 self-start border border-teal-100">
                                        {gat.data.cenario}
                                    </span>
                                    
                                    <h3 class="text-xl font-bold text-gray-800 mb-3 group-hover:text-azul-petroleo transition-colors">
                                        {gat.data.title}
                                    </h3>
                                    
                                    <p class="text-gray-500 text-sm leading-relaxed mb-6 flex-grow text-justify line-clamp-3">
                                        {gat.data.description}
                                    </p>
                                    
                                    <div class="flex items-center text-azul-claro font-bold text-sm mt-auto group-hover:underline decoration-2 underline-offset-4">
                                        Ver equipe e atividades 
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                        </svg>
                                    </div>
                                </div>
                            </a>
                        ))}
                    </div>
                )}
            </section>

        </main>
        <Footer />
    </body>
</html>